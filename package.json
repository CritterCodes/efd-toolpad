    "@mui/icons-material": "^6.3.1",
    "@mui/lab": "^6.0.1-beta.36",
    "@mui/material": "^6.3.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "axios": "^1.13.2",
    "bcryptjs": "^2.4.3",
    "date-fns": "^4.1.0",
    "handlebars": "4.7.8",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.12.0",
    "next": "^15.5.7",
    "next-auth": "^5.0.0-beta.25",
    "next-pwa": "^5.6.0",
    "nodemailer": "^7.0.13",
    "prop-types": "15.8.1",

    "@eslint/eslintrc": "^3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "eslint": "^9",
    "eslint-config-next": "15.1.3",
    "jsdom": "^25.0.1",
    "knip": "^6.23.0",
    "vitest": "^2.1.9"
  }

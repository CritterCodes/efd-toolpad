    "predev:pwa": "node scripts/prepare-next-dir.js",
    "prebuild:pwa": "node scripts/prepare-next-dir.js",
    "dev": "next dev --port 3001",
    "dev:preview": "node scripts/dev-preview.mjs",
    "dev:pwa": "ENABLE_PWA=true next dev --port 3001",
    "build": "next build",
    "build:pwa": "ENABLE_PWA=true next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "next lint",
    "deadcode": "knip",
    "audit:repair-workflow": "node scripts/audit-repair-workflow.mjs",
    "backfill:repair-workflow": "node scripts/backfill-repair-workflow.mjs",
    "backfill:repair-analytics-baseline": "node scripts/backfill-repair-analytics-baseline.mjs",
    "audit:repair-payroll": "node scripts/audit-repair-payroll.mjs",

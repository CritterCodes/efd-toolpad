{
  "installCommand": "pnpm install --no-frozen-lockfile",
  "functions": {
    "src/app/api/*/route.js": {
      "maxDuration": 30
    },
    "src/app/api/artisan/gallery/route.js": {
      "maxDuration": 60
    },
    "src/app/api/cron/update-metal-prices/route.js": {
      "maxDuration": 60
    },
    "src/app/api/cron/birthday-offers/route.js": {
      "maxDuration": 60
    },
    "src/app/api/cron/abandoned-cart/route.js": {
      "maxDuration": 60
    },
    "src/app/api/admin/blog-drafts/[id]/submit/route.js": {
      "maxDuration": 120
    },
    "src/app/api/admin/blog-drafts/[id]/article-edit/route.js": {
      "maxDuration": 120
    },
    "src/app/api/admin/blog-drafts/[id]/publish/route.js": {
      "maxDuration": 60
    },
    "src/app/api/admin/trigger/route.js": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/update-metal-prices",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/birthday-offers",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/abandoned-cart",
      "schedule": "0 * * * *"
    }
  ]
}
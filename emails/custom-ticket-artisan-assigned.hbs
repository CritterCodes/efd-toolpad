<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    body { font-family: Arial, sans-serif; background-color: #f5f5f5; margin: 0; padding: 20px; }
    .container { max-width: 600px; margin: 0 auto; background: #ffffff; border-radius: 8px; overflow: hidden; }
    .header { background-color: #1a1a2e; color: #d4af37; padding: 24px; text-align: center; }
    .header h1 { margin: 0; font-size: 22px; }
    .body { padding: 24px; color: #333; line-height: 1.6; }
    .detail { background: #f9f9f9; padding: 16px; border-radius: 6px; margin: 16px 0; }
    .detail p { margin: 4px 0; }
    .btn { display: inline-block; background: #d4af37; color: #1a1a2e; padding: 12px 24px; border-radius: 6px; text-decoration: none; font-weight: bold; margin-top: 16px; }
    .footer { padding: 16px 24px; text-align: center; font-size: 12px; color: #999; border-top: 1px solid #eee; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>New Custom Ticket Assignment</h1>
    </div>
    <div class="body">
      <p>You have been assigned to a custom design ticket.</p>
      <div class="detail">
        <p><strong>Ticket:</strong> #{{ticketNumber}}</p>
        {{#if ticketTitle}}
        <p><strong>Title:</strong> {{ticketTitle}}</p>
        {{/if}}
        {{#if artisanType}}
        <p><strong>Role:</strong> {{artisanType}}</p>
        {{/if}}
      </div>
      <p>Please review the ticket details and begin working on this project.</p>
      {{#if ticketUrl}}
      <a href="{{ticketUrl}}" class="btn">View Ticket</a>
      {{/if}}
    </div>
    <div class="footer">
      <p>Engel Fine Design &mdash; Custom Jewelry Crafted For You</p>
      <p>Questions? Contact us at {{supportEmail}}</p>
    </div>
  </div>
</body>
</html>
